{
  "name": "agent-isles",
  "version": "0.0.0",
  "description": "Markdown seas, component islands: render agent-authored Markdown with Bootstrap and Lit Web Components.",
  "type": "module",
  "bin": {
    "isles": "./bin/isles.mjs"
  },
  "scripts": {
    "build": "rollup -c",
    "test": "node --test",
    "render": "node ./bin/isles.mjs render examples/demo.md",
    "pretest": "npm run build"
  },
  "keywords": [
    "markdown",
    "web-components",
    "lit",
    "bootstrap",
    "agents",
    "cli"
  ],
  "author": "Zach Young",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zpyoung/agent-isles.git"
  },
  "bugs": {
    "url": "https://github.com/zpyoung/agent-isles/issues"
  },
  "homepage": "https://github.com/zpyoung/agent-isles#readme",
  "dependencies": {
    "lit": "^3.3.2",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "rollup": "^4.60.3"
  }
}
