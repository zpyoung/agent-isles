{
  "name": "agent-isles",
  "version": "0.1.0-alpha.0",
  "description": "Markdown seas, component islands: render agent-authored Markdown with Bootstrap and Lit Web Components.",
  "type": "module",
  "bin": {
    "isles": "./bin/isles.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "dist/agent-components.js",
    "dist/agent-components.js.map",
    "examples/demo.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "npm run test:unit && npm run test:browser",
    "test:unit": "npm run build && node --test tests/*.test.mjs",
    "test:browser": "npm run build && npm run render -- --out dist/demo.html --assets local && playwright test",
    "render": "node ./bin/isles.mjs render examples/demo.md",
    "prepack": "npm run build",
    "pack:dry-run": "npm pack --dry-run"
  },
  "keywords": [
    "markdown",
    "web-components",
    "lit",
    "bootstrap",
    "agents",
    "cli"
  ],
  "author": "Zach Young",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zpyoung/agent-isles.git"
  },
  "bugs": {
    "url": "https://github.com/zpyoung/agent-isles/issues"
  },
  "homepage": "https://github.com/zpyoung/agent-isles#readme",
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@terrastruct/d2": "^0.1.33",
    "bootstrap": "^5.3.3",
    "highlight.js": "^11.9.0",
    "lit": "^3.3.2",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "rollup": "^4.60.3"
  }
}
